            if [[ -n "$from" ]] || [[ -n "$to" ]]; then
                entries_json=$(echo "$entries_json" | jq --arg from "$from" --arg to "$to" \
                    'map(select(.timestamp[0:10] >= $from and .timestamp[0:10] <= $to))' 2>/dev/null || echo "[]")
            fi

            if [[ "$(echo "$entries_json" | jq 'length')" -gt 0 ]]; then
                local models
                models=$(echo "$entries_json" | jq -r '.[].model' | sort -u || echo "")
                for model in $models; do
                    local current
                    current=$(echo "$sessions_by_model" | jq -r ".\"$model\" // 0")
                    sessions_by_model=$(echo "$sessions_by_model" | jq ".\"$model\" = $((current + 1))" 2>/dev/null || echo "{}")
                done

                all_entries=$(echo "$all_entries $entries_json" | jq -s 'add' 2>/dev/null || echo "$all_entries")
            fi
        fi
    done

    messages=$(echo "$all_entries" | jq 'length' 2>/dev/null || echo 0)
    messages_by_model=$(echo "$all_entries" | jq 'group_by(.model) | map({key: .[0].model, value: length}) | from_entries' 2>/dev/null || echo '{}')
    tokens_input=$(echo "$all_entries" | jq 'group_by(.model) | map({key: .[0].model, value: map(.input | tonumber) | add}) | from_entries' 2>/dev/null || echo '{}')
    tokens_output=$(echo "$all_entries" | jq 'group_by(.model) | map({key: .[0].model, value: map(.output | tonumber) | add}) | from_entries' 2>/dev/null || echo '{}')
    usage_by_date=$(echo "$all_entries" | jq 'group_by(.timestamp[0:10]) | map({key: .[0].timestamp[0:10], value: {sessions: (map(.model) | unique | length), messages: length}}) | from_entries' 2>/dev/null || echo '{}')

    local tokens='{}'
    local all_models
    all_models=$(echo "$tokens_input" | jq -r 'keys[]' 2>/dev/null || echo "")
    for model in $all_models; do
        local inp out
        inp=$(echo "$tokens_input" | jq -r ".\"$model\" // 0")
        out=$(echo "$tokens_output" | jq -r ".\"$model\" // 0")
        tokens=$(echo "$tokens" | jq ".\"$model\" = {input: $inp, output: $out}" 2>/dev/null || echo "{}")
    done

    jq -n \
        --argjson found true \
        --argjson sessions "$sessions" \
        --argjson sessions_by_model "$sessions_by_model" \
        --argjson messages "$messages" \
        --argjson messages_by_model "$messages_by_model" \
        --argjson tokens "$tokens" \
        --argjson usage_by_date "$usage_by_date" \
        '{
            found: $found,
            sessions: $sessions,
            sessions_by_model: $sessions_by_model,
            messages: $messages,
            messages_by_model: $messages_by_model,
            tokens: $tokens,
            usage_by_date: $usage_by_date
        }'
}

# --- Main ---

main() {
    check_jq

    local project
    local opencode_json claude_json

    if [[ "$ALL_PROJECTS" == "true" ]]; then
        project=""
        opencode_json=$(load_opencode_all)
        claude_json=$(load_claude_all)
    elif [[ -n "$PROJECT_PATH" ]]; then
        project="$PROJECT_PATH"
        opencode_json=$(load_opencode_stats "$PROJECT_PATH")
        claude_json=$(load_claude_stats "$PROJECT_PATH")
    else
        # Auto-detect project from current directory
        project=$(pwd)
        opencode_json=$(load_opencode_stats "$project")
        claude_json=$(load_claude_stats "$project")

        # If not found, try walking up
        if echo "$opencode_json" | jq -e '.found == false' &>/dev/null && \
           echo "$claude_json" | jq -e '.found == false' &>/dev/null; then
            project=""
            # Try to find by walking up
            local dir
            dir=$(pwd)
            while [[ "$dir" != "/" ]]; do
                local oc_check cl_check
                oc_check=$(load_opencode_stats "$dir")
                cl_check=$(load_claude_stats "$dir")
                if echo "$oc_check" | jq -e '.found == true' >/dev/null 2>&1 || \
                   echo "$cl_check" | jq -e '.found == true' >/dev/null 2>&1; then
                    project="$dir"
                    opencode_json="$oc_check"
                    claude_json="$cl_check"
                    break
                fi
                dir=$(dirname "$dir")
            done
        fi
    fi

    # If still not found and not --all, show helpful error
    if [[ "$ALL_PROJECTS" != "true" ]] && [[ -z "$project" ]]; then
        echo "No LLM usage data found for current directory." >&2
        echo "" >&2
        echo "Nearby projects with data:" >&2

        # List nearby OpenCode projects
        if [[ -d "$OPENCODE_STORAGE/project" ]]; then
            for pf in "$OPENCODE_STORAGE"/project/*.json; do
                if [[ -f "$pf" ]]; then
                    local wt
                    wt=$(jq -r '.worktree' "$pf" 2>/dev/null || echo "")
                    if [[ -n "$wt" ]]; then
                        echo "  - $wt (OpenCode)" >&2
                    fi
                fi
            done
        fi

        # List nearby Claude projects
        if [[ -d "$CLAUDE_PROJECTS" ]]; then
            for pd in "$CLAUDE_PROJECTS"/*; do
                if [[ -d "$pd" ]]; then
                    local name
                    name=$(basename "$pd")
                    # Decode the name
                    local decoded
                    decoded=$(echo "$name" | sed 's/%2F/\//g; s/^-//')
                    echo "  - $decoded (Claude Code)" >&2
                fi
            done
        fi

        exit 1
    fi

    # Output JSON using jq to build the object
    jq -n \
        --arg generated_at "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
        --arg project "$project" \
        --arg from "${FROM_DATE:-}" \
        --arg to "${TO_DATE:-}" \
        --argjson opencode "$opencode_json" \
        --argjson claude "$claude_json" \
        '{
            generated_at: $generated_at,
            project: $project,
            time_range: { from: $from, to: $to },
            opencode: $opencode,
            claude_code: $claude
        }'
}

main
